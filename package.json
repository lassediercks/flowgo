{
  "name": "flowgo-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "description": "TypeScript pure-function modules + Vitest suite for the flowgo editor. Phase 1 mirrors helpers from index.html so future phases can swap them in.",
